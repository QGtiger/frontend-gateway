# NestJS
PORT=3000

# Aliyun OSS（ali-oss client）
ALIOSS_REGION=oss-cn-hangzhou
ALIOSS_ACCESS_KEY_ID=
ALIOSS_ACCESS_KEY_SECRET=
ALIOSS_BUCKET=

# OSS 中 routers 配置 JSON 的对象路径（默认 routers/routers.json）
ALIOSS_ROUTERS_OBJECT_KEY=routers.json

# routers 内存缓存 TTL（毫秒），默认 30000；0=仅在本进程写 OSS 后刷新，不按时间失效
# ROUTERS_DOCUMENT_CACHE_TTL_MS=30000
